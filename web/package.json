{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "docker:dev:up": "docker compose -f docker-compose.dev.yml up --build",
    "docker:dev:up:detached": "docker compose -f docker-compose.dev.yml up -d --build",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:dev:down:volumes": "docker compose -f docker-compose.dev.yml down -v",
    "docker:dev:logs": "docker compose -f docker-compose.dev.yml logs -f web db",
    "docker:dev:migrate": "docker compose -f docker-compose.dev.yml exec web pnpm db:migrate",
    "docker:dev:seed": "docker compose -f docker-compose.dev.yml exec web pnpm db:seed",
    "dev:check": "bash scripts/local-dev-check.sh",
    "dev:webpack": "next dev --webpack",
    "build": "node scripts/migrate.mjs && next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "test:a11y:contrast": "node scripts/a11y-contrast-check.mjs",
    "test:settings:compliance": "node scripts/ios-settings-compliance-gate.mjs",
    "test:settings:compliance:structure": "bash scripts/playwright-wrapper.sh test e2e/ios-settings-compliance.spec.ts --project chromium",
    "test:settings:compliance:a11y": "bash scripts/playwright-wrapper.sh test e2e/ios-settings-a11y.spec.ts --project chromium",
    "test:settings:compliance:visual": "bash scripts/playwright-wrapper.sh test e2e/ios-settings-visual.spec.ts --project chromium",
    "test:settings:compliance:visual:strict": "IOS_SETTINGS_VISUAL_STRICT=1 bash scripts/playwright-wrapper.sh test e2e/ios-settings-visual.spec.ts --project chromium",
    "test:settings:compliance:visual:update": "IOS_SETTINGS_VISUAL_STRICT=1 bash scripts/playwright-wrapper.sh test e2e/ios-settings-visual.spec.ts --project chromium --update-snapshots",
    "test:design:harmonization": "bash scripts/playwright-wrapper.sh test e2e/design-harmonization.spec.ts --project chromium",
    "test:design:harmonization:strict": "DESIGN_HARMONIZATION_VISUAL_STRICT=1 bash scripts/playwright-wrapper.sh test e2e/design-harmonization.spec.ts --project chromium",
    "test:design:harmonization:light": "DESIGN_HARMONIZATION_COLOR_SCHEMES=light bash scripts/playwright-wrapper.sh test e2e/design-harmonization.spec.ts --project chromium",
    "test:design:harmonization:dark": "DESIGN_HARMONIZATION_COLOR_SCHEMES=dark bash scripts/playwright-wrapper.sh test e2e/design-harmonization.spec.ts --project chromium",
    "test:async-ux:continuity": "bash scripts/playwright-wrapper.sh test e2e/async-ux-continuity.spec.ts --project chromium",
    "test:async-ux:stats-1rm": "bash scripts/playwright-wrapper.sh test e2e/stats-1rm-async-continuity.spec.ts --project chromium",
    "test:settings:policy": "tsx --test src/lib/settings/update-setting.test.ts",
    "typecheck": "tsc --noEmit",
    "test:unit": "tsx --test src/server/progression/reducer.test.ts src/lib/settings/update-setting.test.ts src/lib/settings/settings-deeplink.test.ts src/lib/settings/settings-search.test.ts",
    "test:progression": "tsx --test src/server/progression/reducer.test.ts",
    "test:e2e": "bash scripts/playwright-wrapper.sh test",
    "test:e2e:dev": "PLAYWRIGHT_SERVER_MODE=dev bash scripts/playwright-wrapper.sh test",
    "test:e2e:prod": "PLAYWRIGHT_SERVER_MODE=prod bash scripts/playwright-wrapper.sh test",
    "test:e2e:ui": "bash scripts/playwright-wrapper.sh test --ui",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/server/db/seed.ts",
    "db:seed:demo-plans": "WORKOUT_SEED_INCLUDE_DEMO_PLANS=1 tsx src/server/db/seed.ts",
    "db:seed:sync": "node scripts/seed-if-needed.mjs",
    "db:verify:programs": "tsx src/server/db/verifyProgramWorkflows.ts",
    "db:backfill:exercise": "tsx src/server/db/backfillExerciseIds.ts",
    "db:cleanup:ux-events": "tsx src/server/db/cleanupUxEventLog.ts",
    "dev:turbo": "next dev --turbo"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "idb": "^8.0.3",
    "immer": "^11.1.4",
    "next": "16.1.6",
    "pg": "^8.18.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tsx": "^4.21.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
