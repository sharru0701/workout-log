{
  "name": "@workout/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "web·apps/api가 공유하는 프레임워크-무지 도메인/인프라 코드 (source-only TS package)",
  "exports": {
    "./*": "./src/*.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "DATABASE_URL=\"${DATABASE_URL:-postgres://test:test@127.0.0.1:5432/test}\" tsx --test $(find src -name '*.test.ts' | sort)"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "@types/pg": "8.16.0"
  },
  "dependencies": {
    "drizzle-orm": "0.45.1",
    "pg": "8.18.0"
  }
}
