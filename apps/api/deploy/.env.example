# ironlog-api (apps/api) — production env template.
# Copy to apps/api/.env (chmod 600) and fill in. apps/api reads process.env;
# the systemd unit loads this via EnvironmentFile, Docker via --env-file.

# --- Database (required) ---
# Same Postgres the web app uses. Use the Supabase POOLER url for the app runtime.
DATABASE_URL=postgresql://USER:PASS@HOST:6543/postgres?pgbouncer=true

# ⚠️ PRODUCTION: leave DB_SCHEMA UNSET (defaults to `public`, same as prod web).
# Only set DB_SCHEMA=dev for an isolated dev deployment.
# DB_SCHEMA=

# ⚠️ PRODUCTION: leave WORKOUT_AUTH_USER_ID UNSET. It's a LOCAL-DEV auth fallback;
# if set in prod, unauthenticated requests collapse to one shared user.
# WORKOUT_AUTH_USER_ID=

# --- Server ---
# Bind port. Keep on localhost behind a reverse proxy (Caddy/nginx) for TLS.
PORT=8787

# --- Email links / origin (used by password-reset & email-verification links) ---
# getRequestOrigin() prefers this; the reset/verify links must point at the WEB app,
# NOT at apps/api. So set this to the public web URL.
WORKOUT_APP_URL=https://your-web-app.example.com

# --- Email sending (Resend) — optional but needed for recovery/verify emails ---
RESEND_API_KEY=
RESEND_FROM=Workout Log <noreply@your-domain>

# --- Ops endpoint guard (optional, recommended in prod) ---
# If set, GET/POST /api/ops/sessions/prune requires Authorization: Bearer <this>.
WORKOUT_OPS_TOKEN=
